# =============================================================================
# American Outlet — Plantilla de variables de entorno
# -----------------------------------------------------------------------------
# Copiá este archivo a .env.local y rellená los valores reales:
#   cp .env.local.example .env.local
# Este .example SÍ se versiona; .env.local NO (está en .gitignore).
# =============================================================================


# --- GoHighLevel (GHL) — CRM / automatización -------------------------------
# Confidencial: no se nombra públicamente en el sitio.
# PIT = Private Integration Token (Settings > Private Integrations en la location).
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
GHL_MCP_URL=https://services.leadconnectorhq.com/mcp/
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28


# --- Cloudinary — imágenes ---------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=


# --- Analítica ---------------------------------------------------------------
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=


# --- WhatsApp ----------------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=


# --- Sitio -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# --- Supabase — auth del área interna (/panel) -------------------------------
# URL y anon key son públicas (se usan en el navegador).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# PRIVADAS — solo backend / scripts locales. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=
# Solo para el script de seed local (scripts/seed-tiendas.mjs). Opcional.
# Una contraseña por tienda; el script las usa para crear las 3 cuentas.
SEED_PASSWORD_CIUDAD_QUESADA=
SEED_PASSWORD_FORTUNA=
SEED_PASSWORD_FLORENCIA=


# --- Claude (Anthropic) — ingesta de contenido con IA en el panel ------------
# PRIVADA — solo backend (server actions). Nunca exponer al cliente.
# Se usa en la caja "Ingesta con IA" de /panel/planificacion.
ANTHROPIC_API_KEY=
